# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Postgres credentials (shared with docker-compose's `db` service).
POSTGRES_USER=konstanta
POSTGRES_PASSWORD=change_me
POSTGRES_DB=konstanta_edu_presence

# Connection string for `npm run dev` / `npm run db:migrate` on this machine.
# DATABASE_URL=postgres://konstanta:change_me@localhost:5432/konstanta_edu_presence
# Connect to Postgres via the shared transaction-mode pooler (IPv4-only)
DATABASE_URL="postgresql://postgres.eauulodkblfubvolmfiq:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Connect to Postgres via the shared session-mode pooler (used for migrations)
DIRECT_URL="postgresql://postgres.eauulodkblfubvolmfiq:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Secret used to sign the login session cookie. Generate your own with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=your_session_secret_here

# Supabase Configurations
SUPABASE_URL=https://eauulodkblfubvolmfiq.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_VJSEetnjK-Wmco1G0uyhew_IkxRn4_v
SUPABASE_SECRET_KEY=your_supabase_secret_key_here
SUPABASE_JWKS_URL=https://eauulodkblfubvolmfiq.supabase.co/auth/v1/.well-known/jwks.json

# Additional configurations used by Docker Compose and VPS deployment
NEXT_PUBLIC_SITE_URL=https://konstanta.my.id
NEXT_PUBLIC_SUPABASE_URL=https://eauulodkblfubvolmfiq.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key_here
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number_here
